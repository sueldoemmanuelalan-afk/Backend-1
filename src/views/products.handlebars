<div class="container">
  <h1>🛍️ Saga Store</h1>

  <div id='productsContainer'>
    {{#each products}}
      <div class="product-card">
        <h2>{{this.title}}</h2>
        {{#if this.description}}
          <p>{{this.description}}</p>
        {{/if}}
        {{#if this.category}}
          <p><strong>Categoría:</strong> {{this.category}}</p>
        {{/if}}
        <div class="price">${{this.price}}</div>
        {{#if this.stock}}
          <p class="stock">Stock: {{this.stock}} unidades</p>
        {{else}}
          <p class="stock">Sin stock</p>
        {{/if}}
        {{#if this.code}}
          <p><strong>Código:</strong> {{this.code}}</p>
        {{/if}}
        <span class="status {{#if this.status}}active{{else}}inactive{{/if}}">{{#if this.status}}Disponible{{else}}No disponible{{/if}}</span>
        <div class="button-group">
          <a href="/products/{{this._id}}" class="btn">Ver detalles</a>
          {{#if this.stock}}
            <form action="/api/carts/{{../cartId}}/products/{{this._id}}" method="POST" style="display: inline-block;">
              <button type="submit" class="btn">Agregar al carrito</button>
            </form>
          {{else}}
            <button class="btn" disabled>Sin stock</button>
          {{/if}}
        </div>
      </div>
    {{/each}}
  </div>

  <div class="pagination">
    {{#if hasPrevPage}}
      <a href='/products?page={{prevPage}}'>⬅ Anterior</a>
    {{/if}}

    {{#if hasNextPage}}
      <a href='/products?page={{nextPage}}'>Siguiente ➡</a>
    {{/if}}
  </div>
</div>

<script src='/socket.io/socket.io.js'></script>
